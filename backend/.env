# 小红书 Cookie
XHS_COOKIES=your_cookie

# 百度千帆 Bearer Token，具体参考百度云LLM文档
QIANFAN_BEARER_TOKEN=your_LLM_token
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2/chat/completions
#指定llm大模型，具体参考百度云LLM文档
QIANFAN_MODEL=qwen3-14b

# MCP 连接池大小/可修改
MCP_POOL_SIZE=3


# HTTP 代理（用于绕过服务器IP封禁，留空则不使用代理）
# 格式示例：XHS_PROXY=http://127.0.0.1:7890
XHS_PROXY=
